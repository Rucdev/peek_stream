# Cloudflare Tunnel Token
# Get this from https://one.dash.cloudflare.com/
# Create a tunnel and copy the token
TUNNEL_TOKEN=your_tunnel_token_here

# Cloudflare TURN API Key (optional)
# Get this from Cloudflare Calls TURN service
# Leave empty to use public STUN servers only
CLOUDFLARE_TURN_API_KEY=
